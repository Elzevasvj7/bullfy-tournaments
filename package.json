{
  "name": "bullfy-tournaments",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File scripts/db-migrate.ps1",
    "db:migrate:remote": "node scripts/db-apply.mjs migrations",
    "db:seed": "powershell -ExecutionPolicy Bypass -File scripts/db-seed.ps1",
    "db:seed:remote": "node scripts/db-apply.mjs seeds",
    "db:remote": "pnpm db:migrate:remote && pnpm db:seed:remote",
    "db:demo": "pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@react-three/fiber": "^9.6.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "klinecharts": "10.0.0-beta3",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "recharts": "3.8.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
